rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Users collection - allow read for email-based queries (mobile app authentication)
    match /users/{userId} {
      allow read: if true; // Allow reading users for email-based authentication
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /points_purchase_requests/{requestId} {
      allow create: if true;
      allow read, update: if request.auth != null && request.auth.token.admin == true;
    }

    // Orders collection - users can read their own orders, admins can read all
    match /orders/{orderId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.auth.token.admin == true
      );
      allow write: if request.auth != null && (
        request.resource.data.userId == request.auth.uid || 
        request.auth.token.admin == true
      );
    }

    // Products collection - anyone can read, only admins can write
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Categories collection - anyone can read, only admins can write
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Food products collection - anyone can read, only admins can write
    match /food_products/{productId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Inventory collection - only admins can access
    match /inventory/{itemId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Inventory history collection - only admins can access
    match /inventory_history/{historyId} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Points settings - allow authenticated users to read plans, only admins can modify
    match /admin/pointsSettings {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Contact settings - allow public read (for WhatsApp button), only admins can write
    match /admin/contactSettings {
      allow read: if true; // Public read for WhatsApp number
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Quick actions - allow public read (for header navigation), only admins can write
    match /admin/quickActions {
      allow read: if true; // Public read for header navigation items
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Admin settings - only admins can access other documents
    // Note: More specific rules (pointsSettings, contactSettings, quickActions) are evaluated first
    match /admin/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Analytics collection - only admins can access
    match /analytics/{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Sales teams collection - only admins can access
    match /salesTeams/{teamId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.role == "salesTeam"
      );
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Sales members collection - admins and sales teams can access
    match /salesMembers/{memberId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true || 
        request.auth.token.role == "salesTeam" ||
        request.auth.token.role == "salesMember"
      );
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.auth.token.role == "salesTeam"
      );
    }

    // Points transactions collection - users can read and write their own transactions
    match /point_transactions/{transactionId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid || 
        request.auth.token.admin == true
      );
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // Complaints collection - restaurants can create complaints, suppliers can read their own complaints
    match /complaints/{complaintId} {
      allow read: if request.auth != null && (
        request.auth.token.admin == true ||
        resource.data.supplierId == request.auth.uid ||
        resource.data.userId == request.auth.uid
      );
      allow write: if request.auth != null && (
        request.auth.token.admin == true ||
        request.resource.data.userId == request.auth.uid
      );
    }

    // Pages collection (CMS) - allow public read for public-facing pages
    match /pages/{pageId} {
      // Allow anyone to read public CMS pages (for banners and content display)
      // Public pages: mobile-app, about, partners, faq, contact, pricing, footer, and all service pages
      allow read: if (
        pageId == 'mobile-app' || // Public read for mobile-app page
        pageId == 'about' || // Public read for about page
        pageId == 'partners' || // Public read for partners page
        pageId == 'faq' || // Public read for FAQ page
        pageId == 'contact' || // Public read for contact page
        pageId == 'pricing' || // Public read for pricing page
        pageId == 'footer' || // Public read for footer page
        pageId == 'dishes-tableware' || // Public read for service pages
        pageId == 'promotion' ||
        pageId == 'restaurant-systems' ||
        pageId == 'restaurant-furniture' ||
        pageId == 'restaurant-maintenance' ||
        pageId == 'restaurant-construction' ||
        pageId == 'kitchen-equipment' ||
        (request.auth != null && request.auth.token.admin == true) // Admins can read all pages
      );
      // Only admins can write
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Settings collection - anyone can read, only admins can write
    match /settings/{settingId} {
      allow read: if true; // Anyone can read settings (logo, etc.)
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // User favorites subcollection
    match /users/{userId}/favorites/{favoriteId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Carts collection - users can read/write only their own cart (doc id == Firebase Auth uid)
    match /carts/{cartId} {
      allow read, write: if request.auth != null && request.auth.uid == cartId;
    }

    // Default rule - deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
} 